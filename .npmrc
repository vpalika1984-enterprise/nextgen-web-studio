# Next.js 15.0.3's peer dependency range for react/react-dom points at an
# exact React 19 release-candidate build rather than the stable 19.0.0
# release, which causes npm's strict ERESOLVE algorithm to fail even though
# React 19.0.0 stable is what we actually want to use. legacy-peer-deps
# relaxes peer resolution so installs succeed consistently in CI and local
# development. Revisit/remove once next is upgraded past this transitional
# release.
legacy-peer-deps=true
